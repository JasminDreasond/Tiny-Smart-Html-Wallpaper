# Mode: "slideshow" | "single"
ENGINE_MODE="slideshow"

# Order: "sequence" | "random"
SLIDESHOW_ORDER="sequence"

# Interval in milliseconds (e.g., 60000 = 1 minute)
SLIDESHOW_INTERVAL=60000

# Default Display: "scaled_cropped" | "scaled" | "cropped" | "normal" | "tiled"
DEFAULT_DISPLAY="scaled_cropped"