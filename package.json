{
  "name": "smart-html-wallpaper-engine",
  "version": "1.0.0",
  "repository": "https://github.com/Tiny-Essentials/Tiny-Smart-Html-Wallpaper.git",
  "bugs": {
    "url": "https://github.com/Tiny-Essentials/Tiny-Smart-Html-Wallpaper/issues"
  },
  "homepage": "https://github.com/Tiny-Essentials/Tiny-Smart-Html-Wallpaper#readme",
  "description": "A smart html wallpaper engine and configurator.",
  "author": "Yasmin Seidel (JasminDreasond)",
  "type": "module",
  "main": "main.js",
  "license": "AGPL-3.0-only",
  "keywords": [
    "electronjs",
    "wallpaper-engine",
    "desktop-customization",
    "slideshow-maker",
    "esbuild",
    "slideshow"
  ],
  "scripts": {
    "start": "electron .",
    "build:web": "node build.js",
    "build:app": "electron-builder --linux --win",
    "prettier": "prettier --write ./web/src/* && prettier --write ./gui/* && prettier --write ./build.js && prettier --write ./main.js && prettier --write ./preload.js && prettier --write ./folders.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "esbuild-wasm": "^0.27.3",
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jasmindreasond.smarthtmlwallpaper",
    "productName": "Smart Html Wallpaper Configurator",
    "directories": {
      "output": "release/"
    },
    "files": [
      "example.env",
      "wallpapers-example.json",
      "folders.js",
      "main.js",
      "preload.js",
      "build.js",
      "gui/**/*",
      "web/src/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/esbuild/**/*",
      "node_modules/@esbuild/**/*",
      "node_modules/esbuild-wasm/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "favicon/favicon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "favicon/favicon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "favicon/favicon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
